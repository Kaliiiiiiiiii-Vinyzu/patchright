+type TypedArrayKind = 'i8' | 'ui8' | 'ui8c' | 'i16' | 'ui16' | 'i32' | 'ui32' | 'f32' | 'f64' | 'bi64' | 'bui64';
+
+export type SerializedValue =
+  | undefined
+  | boolean
+  | number
+  | string
+  | { v: 'null' | 'undefined' | 'NaN' | 'Infinity' | '-Infinity' | '-0' }
